# --- Contact form delivery (optional but recommended) ---
# Get a key at https://resend.com (free tier covers this site).
# When unset, contact form submissions are logged but no email is sent.
RESEND_API_KEY=

# Where contact-form notifications are delivered.
CONTACT_TO_EMAIL=hello@synapsedynamicssegmented.com

# From address. Until a custom domain is verified in Resend,
# leave this UNSET — it falls back to onboarding@resend.dev.
# Once your domain is verified in Resend, set this to e.g.:
# CONTACT_FROM_EMAIL="Synapse Dynamics <hello@synapsedynamicssegmented.com>"
CONTACT_FROM_EMAIL=
